# ============================================================
# MIDAS_D3 — Production Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# ── Database ─────────────────────────────────────────────────
MIDAS_DB_USERNAME=midas
MIDAS_DB_PASSWORD=change_me_strong_password

# ── Security ─────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
MIDAS_JWT_SECRET=replace_with_a_long_random_base64_string

# ── Gemini LLM ───────────────────────────────────────────────
MIDAS_LLM_BASE_URL=https://generativelanguage.googleapis.com
MIDAS_LLM_API_KEY=your_gemini_api_key_here
MIDAS_LLM_MODEL=gemini-2.0-flash

# ── Nous / OpenAI-compatible LLM ─────────────────────────────
MIDAS_NOUS_BASE_URL=https://openrouter.ai/api
MIDAS_NOUS_API_KEY=your_nous_api_key_here
MIDAS_NOUS_MODEL=nous-hermes-2-mistral-7b-dpo
MIDAS_NOUS_TIMEOUT_SECONDS=120
MIDAS_NOUS_MAX_RETRIES=2

# ── Scheduler ────────────────────────────────────────────────
MIDAS_EVOLUTION_CRON=0 0 * * * *

# ── Telegram (set ENABLED=true to activate) ──────────────────
MIDAS_TELEGRAM_ENABLED=false
MIDAS_TELEGRAM_BOT_USERNAME=midas_pipeline_bot
MIDAS_TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram chat IDs (optional whitelist). Leave empty to allow any chat.
# MIDAS_TELEGRAM_ALLOWED_CHAT_IDS=123456789

# ── Frontend ─────────────────────────────────────────────────
# Replace localhost with your VPS domain or public IP.
# This value is BAKED INTO the JS bundle at build time.
# You must rebuild the frontend image after changing it.
NEXT_PUBLIC_API_BASE_URL=http://YOUR_VPS_IP_OR_DOMAIN:8080
