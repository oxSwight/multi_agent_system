# ============================================================
# MIDAS — Environment Variables
# Copy to `.env` and fill in the values:  cp .env.example .env
# NEVER commit .env (it is git-ignored).
# Every variable here overrides a default in application.yml.
# ============================================================

# ── Database (PostgreSQL) ────────────────────────────────────
MIDAS_DB_URL=jdbc:postgresql://db:5432/midas_db
MIDAS_DB_USERNAME=midas
MIDAS_DB_PASSWORD=change_me_strong_password

# ── Security ─────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
# Must be a Base64-encoded HMAC-SHA256 key (>= 256 bits).
MIDAS_JWT_SECRET=replace_with_a_long_random_base64_string

# ============================================================
# LLM PROVIDER — pick ONE client via MIDAS_LLM_CLIENT_TYPE
#   NOUS   → OpenAI-compatible endpoint (Ollama / OpenRouter / LM Studio)  [default]
#   GEMINI → Google AI Studio
# ============================================================
MIDAS_LLM_CLIENT_TYPE=NOUS

# ── Option A: NOUS / OpenAI-compatible (active by default) ────
# Local Ollama (from a container, reach the host):
MIDAS_NOUS_BASE_URL=http://host.docker.internal:11434
MIDAS_NOUS_API_KEY=ollama-local-dev
MIDAS_NOUS_MODEL=qwen2.5-coder:14b
MIDAS_NOUS_TIMEOUT_SECONDS=300
MIDAS_NOUS_MAX_RETRIES=2
# Per-agent model routing (all default to the engineering model below):
MIDAS_NOUS_ROUTING_ENABLED=true
MIDAS_NOUS_ROUTING_DEFAULT_MODEL=qwen2.5-coder:14b
MIDAS_NOUS_MODEL_ENGINEERING=qwen2.5-coder:14b
# OpenRouter alternative:  MIDAS_NOUS_BASE_URL=https://openrouter.ai/api
#                          MIDAS_NOUS_API_KEY=sk-or-...
# LM Studio alternative:   MIDAS_NOUS_BASE_URL=http://localhost:1234  (empty API key)

# ── Option B: Google Gemini (only used when CLIENT_TYPE=GEMINI) ─
MIDAS_LLM_BASE_URL=https://generativelanguage.googleapis.com
MIDAS_LLM_API_KEY=your_gemini_api_key_here
MIDAS_LLM_MODEL=gemini-2.5-flash
MIDAS_LLM_MODEL_CODE=gemini-2.5-flash
MIDAS_LLM_MODEL_TEST=gemini-2.5-flash

# ── Scheduler ────────────────────────────────────────────────
# Evolution agent cron (Spring 6-field). Set to "-" to disable.
MIDAS_EVOLUTION_CRON=0 0 * * * *

# ── Telegram bot (set ENABLED=true to activate) ──────────────
MIDAS_TELEGRAM_ENABLED=false
MIDAS_TELEGRAM_BOT_USERNAME=midas_pipeline_bot
MIDAS_TELEGRAM_BOT_TOKEN=
# Optional comma-separated chat-ID whitelist. Leave empty to allow any chat.
# MIDAS_TELEGRAM_ALLOWED_CHAT_IDS=123456789

# ── Frontend (Next.js dashboard) ─────────────────────────────
# BAKED INTO the JS bundle at build time — rebuild the frontend image after
# changing it. Replace localhost with your VPS domain or public IP for remote use.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
