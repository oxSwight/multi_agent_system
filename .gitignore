target/
*.class
*.jar
*.war
*.ear
hs_err_pid*
replay_pid*

# ── Node / Next.js ───────────────────────────────────────────
node_modules/
.next/
out/
dist/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── IDE & OS ─────────────────────────────────────────────────
.idea/
*.iml
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ── Logs & temp ──────────────────────────────────────────────
*.log
logs/
tmp/
temp/
.tmp-*

# Internal project specifications / scratch notes
/.internal/

# ── Build & tooling noise ────────────────────────────────────
midas_hybrid.zip
.cursor_run_id.txt

# ── Markdown ─────────────────────────────────────────────────
# Ignore ad-hoc scratch notes by default, but always track the
# canonical project docs so a contributor's CONTRIBUTING/SECURITY/
# CHANGELOG can't silently vanish from version control.
*.md
!README.md
!**/README.md
!CONTRIBUTING.md
!CODE_OF_CONDUCT.md
!SECURITY.md
!CHANGELOG.md
!LICENSE.md
!MIDAS_DX_TODO.md
!docs/**/*.md
